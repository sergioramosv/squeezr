    "claude",
    "claude-code",
    "codex",
    "ollama",
    "aider",
    "gemini",
    "token",
    "compression",
    "proxy",
    "llm",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sergioramosv/Squeezr"
  },
  "homepage": "https://github.com/sergioramosv/Squeezr#readme",
  "type": "module",
  "bin": {
    "squeezr": "./bin/squeezr.js"
  },
  "scripts": {
