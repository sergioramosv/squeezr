{
  "name": "squeezr-ai",
  "version": "1.24.0",
  "description": "AI proxy that compresses Claude Code, Codex, Aider, Gemini CLI and Ollama context windows to save thousands of tokens per session",
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "ollama",
    "aider",
    "gemini",
    "token",
    "compression",
    "proxy",
    "llm",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergioramosv/Squeezr.git"
  },
  "homepage": "https://github.com/sergioramosv/Squeezr#readme",
  "type": "module",
  "bin": {
    "squeezr": "bin/squeezr.js",
    "squeezr-mcp": "dist/mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "node -e \"['dist/cursorMitm.js','dist/cursorMitm.d.ts','dist/__tests__/cursorMitm.test.js','dist/__tests__/cursorMitm.test.d.ts'].forEach(f=>{try{require('fs').unlinkSync(f)}catch{}})\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "gain": "node dist/gain.js",
    "discover": "node dist/discover.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "bin/",
    "dist/",
    "squeezr.toml"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@bufbuild/protobuf": "^2.11.0",
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.7.5",
    "node-forge": "^1.4.0",
    "openai": "^4.93.0",
    "smol-toml": "^1.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/node-forge": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
